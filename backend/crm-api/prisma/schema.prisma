// ============================================
// Xeno CRM — Prisma Schema
// Database: Supabase PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Customer
// ============================================
model Customer {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  phone            String?
  city             String?
  totalSpend       Float           @default(0)
  orderCount       Int             @default(0)
  lastPurchaseDate DateTime?
  createdAt        DateTime        @default(now())

  orders           Order[]
  communications   Communication[]
}

// ============================================
// Order
// ============================================
model Order {
  id              String   @id @default(cuid())
  customerId      String
  amount          Float
  productCategory String?
  orderDate       DateTime @default(now())
  createdAt       DateTime @default(now())

  // Last-touch attribution: the communication/campaign credited for this order.
  // Null when the order was not preceded by an engaged communication.
  campaignId      String?
  communicationId String?

  customer        Customer       @relation(fields: [customerId], references: [id])
  campaign        Campaign?      @relation(fields: [campaignId], references: [id])
  communication   Communication? @relation(fields: [communicationId], references: [id])

  @@index([customerId])
  @@index([campaignId])
}

// ============================================
// Campaign
// ============================================
model Campaign {
  id             String          @id @default(cuid())
  name           String
  goal           String?
  channel        String          @default("email")
  message        String?
  segmentQuery   String?         // human-readable natural-language audience description
  segmentFilter  String?         // JSON-stringified executable filter applied at launch
  audienceSize   Int             @default(0)
  status         String          @default("draft")
  createdAt      DateTime        @default(now())

  communications   Communication[]
  attributedOrders Order[]
}

// ============================================
// Communication
// ============================================
model Communication {
  id         String               @id @default(cuid())
  campaignId String
  customerId String
  channel    String               @default("email")
  message    String?
  status     String               @default("pending")
  createdAt  DateTime             @default(now())

  campaign         Campaign             @relation(fields: [campaignId], references: [id])
  customer         Customer             @relation(fields: [customerId], references: [id])
  events           CommunicationEvent[]
  attributedOrders Order[]

  @@index([customerId])
  @@index([campaignId])
}

// ============================================
// CommunicationEvent
// ============================================
model CommunicationEvent {
  id              String        @id @default(cuid())
  communicationId String
  eventType       String
  createdAt       DateTime      @default(now())

  communication   Communication @relation(fields: [communicationId], references: [id])
}

// ============================================
// AI Insight Cache
// Persistent storage for Gemini responses
// ============================================
model AIInsightCache {
  id          String   @id @default(cuid())
  type        String   // "analytics" or "campaign_analysis"
  entityId    String?  // null for global analytics, campaignId for campaign_analysis
  content     String   // JSON stringified insights array
  snapshot    String?  // JSON stringified state of metrics at generation time
  generatedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, entityId]) // Ensure only one cache entry per type/entity combo
}